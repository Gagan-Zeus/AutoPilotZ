{
  "manifest_version": 3,
  "name": "AutoPilotX",
  "description": "Secure profile vault and AI-assisted form field mapper.",
  "version": "0.1.0",
  "action": {
    "default_title": "AutoPilotX"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "sidePanel", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
  },
  "content_scripts": []
}
